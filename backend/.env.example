# ============================================================
#  LOGOS — Backend Environment Variables
#  Copie este arquivo para .env e preencha os valores
# ============================================================

# Servidor
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://postgres:senha@localhost:5432/logos_dev
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT — gere um secret forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_um_secret_forte_aqui
JWT_EXPIRES_IN=7d

# Cookies
COOKIE_SECRET=troque_por_outro_secret_forte_aqui

# OAuth Google (opcional na v1)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Armazenamento de PDFs exportados
# 'local' salva em ./tmp/exports | 's3' usa AWS S3
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./tmp/exports

# S3 (opcional — preencher apenas se STORAGE_DRIVER=s3)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
